
# ── Database ──────────────────────────────────────────────────
SUPABASE_DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Strategy (Volatility-Barrier / z-score) ───────────────────
MARKET_WINDOW=5M
# Only evaluate entries in the final N seconds before window close.
ENTRY_FROM_WINDOW_SECONDS=30
# Only buy when the executable ask sits within [ENTRY_PRICE_FLOOR, MAX_ENTRY_PRICE].
# Below the floor the market prices us as an underdog (where the losses live).
ENTRY_PRICE_FLOOR=0.5
MAX_ENTRY_PRICE=0.98
# Enter the favorite only when z = signedDistance / (sigma * sqrt(secondsLeft)) >= this.
Z_ENTRY_THRESHOLD=3.0
# Trailing window (ms) for estimating BTC realized per-second volatility.
SIGMA_WINDOW_MS=60000
# Require (barrier fair value - price) >= this to enter. 0 disables the check.
MIN_ENTRY_EDGE=0
# Stop-loss: market-sell the position when the executable bid falls STOP_LOSS_DELTA below entry.
STOP_LOSS_ENABLED=true
STOP_LOSS_DELTA=0.20
# Simulated submit→match round-trip for exits; the book moves in between.
EXECUTION_LATENCY_MS=250
SCAN_INTERVAL_MS=60000

# ── Risk Guardrails ───────────────────────────────────────────
CONSECUTIVE_LOSS_PAUSE_LIMIT=3
RISK_AUTO_RESUME_ENABLED=false
RISK_AUTO_RESUME_COOLDOWN_MS=300000

# ── Portfolio / Sizing ────────────────────────────────────────
STARTING_CAPITAL=10
# Position budget = clamp(totalPortfolioValue / BUDGET_DIVISOR, BUDGET_MIN_USD, BUDGET_MAX_USD).
BUDGET_DIVISOR=5
BUDGET_MIN_USD=5
BUDGET_MAX_USD=20

# ── API Server ────────────────────────────────────────────────
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=production
ADMIN_PASSWORD=change_me_to_something_secure
