
# ── Database ──────────────────────────────────────────────────
SUPABASE_DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Strategy ──────────────────────────────────────────────────
MARKET_WINDOW=5M
TRADE_FROM_WINDOW_SECONDS=90
ENTRY_PRICE_THRESHOLD=0.94
MAX_ENTRY_PRICE=0.98
MAX_SIMULTANEOUS_POSITIONS=5
MIN_BTC_DISTANCE_USD=50
SCAN_INTERVAL_MS=60000

# ── Stop-Loss ─────────────────────────────────────────────────
STOP_LOSS_ENABLED=true
STOP_LOSS_PRICE_TRIGGER=0.75
STOP_LOSS_HOLDOFF_SECONDS=40

# ── Momentum Filter ──────────────────────────────────────────
MOMENTUM_ENABLED=true
MOMENTUM_LOOKBACK_MS=90000
MOMENTUM_MIN_CHANGE_USD=20

# ── Portfolio ─────────────────────────────────────────────────
STARTING_CAPITAL=10

# ── API Server ────────────────────────────────────────────────
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=production
ADMIN_PASSWORD=change_me_to_something_secure
