# ═══════════════════════════════════════════════════════════════
# PenguinX BTC Analysis — Backend Environment Configuration
# Momentum-Enhanced High-Prob Scalping Strategy (5-Min BTC)
# Copy this file to .env and fill in real values.
# ═══════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────
# Supabase connection string (required)
SUPABASE_DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Strategy ──────────────────────────────────────────────────
# Market window type to target: 5M | 15M | 1H | 4H | 1D
MARKET_WINDOW=5M

# Seconds before window close to allow entries
TRADE_FROM_WINDOW_SECONDS=60

# ── Entry price range ─────────────────────────────────────────
# Minimum midpoint to consider entry (94¢+)
# Below this the expected value is too uncertain
ENTRY_PRICE_THRESHOLD=0.94

# Maximum midpoint to allow entry (97¢ ceiling)
# Above this payoff spread is too thin (pay 97¢, collect $1 = only 3¢ upside)
# Enforced at strategy engine evaluation time AND at fill simulation
MAX_ENTRY_PRICE=0.97

# Max concurrent open positions
MAX_SIMULTANEOUS_POSITIONS=3

# BTC must have moved at least this USD from the window-open price
# Filters out noise; $50 is a meaningful 5-min BTC move
MIN_BTC_DISTANCE_USD=50

# Market scanner run interval (ms). 60s is fine for 5-min markets.
SCAN_INTERVAL_MS=60000

# ── Simulation ────────────────────────────────────────────────
# Simulated USD per trade (paper trading — no real money)
SIMULATION_AMOUNT_USD=1

# ── Stop-Loss ─────────────────────────────────────────────────
# Recommended: DISABLED for binary markets that resolve in <5min.
# A stop-loss crystallizes losses that may have recovered at resolution.
STOP_LOSS_ENABLED=false
STOP_LOSS_THRESHOLD=0.85

# ── Momentum Filter ───────────────────────────────────────────
# Only trade when BTC price momentum aligns with the market direction.
# Uses existing RTDS WebSocket price history — no extra data source needed.
MOMENTUM_ENABLED=true

# Lookback window in ms (default: 90s = 90000)
# Shorter = faster, noisier; Longer = smoother, slightly lagging
MOMENTUM_LOOKBACK_MS=90000

# Minimum BTC USD change over the lookback to be non-neutral
# Below this threshold = BTC is ranging, no directional edge → skip
MOMENTUM_MIN_CHANGE_USD=30

# ── API Server ────────────────────────────────────────────────
PORT=4000
HOST=0.0.0.0

# ── Logging ───────────────────────────────────────────────────
# Level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# ── Environment ───────────────────────────────────────────────
NODE_ENV=production

# ── Admin ─────────────────────────────────────────────────────
# Password for the DELETE /api/admin/wipe endpoint
WIPE_PASSWORD=change_me_to_something_secure
